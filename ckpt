def cmd_restore(args):
    root = project_root()
    if not args.ref:
        return _restore_interactive(root)
    ref = _resolve_ref(root, args.ref)
    if not ref:
        die(f"checkpoint not found: {args.ref}")
    if args.path:
        r = op_restore_file(root, ref, args.path)
        if r["ok"]:
            print(f"restored: {args.path}  (from {ref.split('/', 2)[-1]})")
        else:
            die(r.get("error") or "restore failed")
        return
    _confirm_full_restore(root, ref)


def _restore_interactive(root):
    rows = list_checkpoints(root)
    if not rows:
        die("no checkpoints")
    has_fzf = shutil.which("fzf") is not None
    if has_fzf:
        lines = []
        for r in rows:
            stat = f"+{r['stats']['insertions']} -{r['stats']['deletions']} · {r['stats']['files']}f"
            lines.append(f"{r['ref']}\t{r['when']:<14}  {_format_msg(r['message']):<55}  {r['id']}  {stat}")
        try:
            res = subprocess.run(
                ["fzf", "--delimiter=\t", "--with-nth=2", "--prompt=restore to> ",
                 "--height=80%", "--reverse", "--no-mouse",
                 "--preview", "git diff {1}^ {1} 2>/dev/null | head -200",
                 "--preview-window=right:60%:wrap",
                 "--header=↑/↓ navigate · / search · enter restore · esc cancel"],
                input="\n".join(lines), capture_output=True, text=True,
            )
            if res.returncode != 0 or not res.stdout.strip():
                print("aborted")
                return
            target = res.stdout.split("\t", 1)[0].strip()
        except FileNotFoundError:
            has_fzf = False
    if not has_fzf:
        for i, r in enumerate(rows, 1):
            print(f"{i:3}) {r['when']:<14}  {_format_msg(r['message']):<55}  {r['id']}")
        print()
        choice = input("select number (empty to cancel): ").strip()
        if not choice:
            print("aborted")
            return
        if not choice.isdigit():
            die(f"invalid number: {choice}")
        n = int(choice)
        if n < 1 or n > len(rows):
            die(f"no checkpoint at index {n}")
        target = rows[n - 1]["ref"]
    _confirm_full_restore(root, target)


def _confirm_full_restore(root, ref):
    cid = ref.rsplit("/", 1)[-1]
    print()
    print(f"  Checkpoint: {cid}")
    stat_out, _, _ = git("diff", "--stat", f"{ref}^", ref, cwd=root)
    for line in stat_out.splitlines():
        print(f"    {line}")
    print()
    print("  This will reset your working tree and index to this checkpoint.")
    print(f"  Current state is snapshotted to '{TRASH_REF}' so 'ckpt undo' can recover it.")
    print("  Later checkpoints are kept — restore forward at any time.")
    print()
    ans = input("  proceed? [y/N] ").strip().lower()
    if ans != "y":
        print("aborted")
        return
    r = op_restore_full(root, ref)
    if not r["ok"]:
        die(r.get("error") or "restore failed")
    print(f"  restored to: {cid}")
    if r.get("safety"):
        print("  to undo: ckpt undo")


