# ---------------- git wrappers ----------------

def git(*args, cwd=None):
    """Run git in a project dir and return (stdout, stderr, returncode)."""
    r = subprocess.run(["git", *args], capture_output=True, text=True, cwd=cwd)
    return r.stdout, r.stderr, r.returncode


def is_git_repo(cwd=None):
    _, _, code = git("rev-parse", "--git-dir", cwd=cwd)
    return code == 0


def project_root(cwd=None):
    out, _, code = git("rev-parse", "--show-toplevel", cwd=cwd)
    return out.strip() if code == 0 else (cwd or os.getcwd())


def claude_project_dir():
    """Best-effort detection of the project Claude Code thinks we're in."""
    return os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()


# ---------------- per-project db ----------------
#
# The DB lives under USER_DATA_DIR (out of the working tree) so a checkpoint
# restore can never wipe it. Older installs kept it at `<project>/.claude/
# checkpoints.db`; the first call into `project_db_path` migrates that file
# (and its SQLite sidecars) into the new location.

def project_data_dir(root):
    pid = project_id_for(root)
    return USER_DATA_DIR / "projects" / pid


_MIGRATED_DB_ROOTS = set()
_MIGRATED_DB_LOCK = threading.Lock()


def _migrate_in_tree_db(root):
    """Move `<root>/.claude/checkpoints.db*` into the new per-project data
    dir. Idempotent; safe to call from any code path that touches the DB."""
    with _MIGRATED_DB_LOCK:
        if root in _MIGRATED_DB_ROOTS:
            return
        _MIGRATED_DB_ROOTS.add(root)
    new_dir = project_data_dir(root)
    new_dir.mkdir(parents=True, exist_ok=True)
    for rel in (PROJECT_DB_REL,
                PROJECT_DB_REL + "-journal",
                PROJECT_DB_REL + "-wal",
                PROJECT_DB_REL + "-shm"):
        src = Path(root) / rel
        if not src.exists():
            continue
        dst = new_dir / Path(rel).name
        if dst.exists():
            # New location already has data — assume it's the live one and
            # discard the stray in-tree copy (probably re-materialized by a
            # restore of a pre-migration snapshot).
            try: src.unlink()
            except Exception: pass
            continue
        try:
            shutil.move(str(src), str(dst))
        except Exception:
            pass


def project_db_path(root):
    _migrate_in_tree_db(root)
    return project_data_dir(root) / "checkpoints.db"


PROJECT_SCHEMA = """
CREATE TABLE IF NOT EXISTS prompts (
    session_id   TEXT NOT NULL,
    submitted_at INTEGER NOT NULL,
    prompt       TEXT NOT NULL,
    PRIMARY KEY (session_id, submitted_at)
);
CREATE TABLE IF NOT EXISTS checkpoints (
    id            TEXT PRIMARY KEY,
    session_id    TEXT,
    prompt        TEXT,
    created_at    INTEGER,
    files_changed INTEGER,
    insertions    INTEGER,
    deletions     INTEGER,
    source        TEXT,
    starred       INTEGER DEFAULT 0
);
CREATE INDEX IF NOT EXISTS idx_prompts_session_time ON prompts(session_id, submitted_at DESC);
"""

# Known agent sources. The UI color-codes these; unknown values render with a
# neutral indicator and the literal source text in a tooltip.
KNOWN_SOURCES = ("claude", "codex")


def project_db_connect(root, create=True):
    path = project_db_path(root)
    if not path.exists() and not create:
        return None
    path.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(path))
    conn.executescript(PROJECT_SCHEMA)
    # Migrate older schemas: add columns added after release.
    cols = {r[1] for r in conn.execute("PRAGMA table_info(checkpoints)").fetchall()}
    for col, decl in (("files_changed", "INTEGER"),
                      ("insertions",    "INTEGER"),
                      ("deletions",     "INTEGER"),
                      ("source",        "TEXT"),
                      ("starred",       "INTEGER DEFAULT 0")):
        if col not in cols:
            conn.execute(f"ALTER TABLE checkpoints ADD COLUMN {col} {decl}")
    conn.commit()
    return conn


# ---------------- per-machine projects db ----------------

PROJECTS_SCHEMA = """
CREATE TABLE IF NOT EXISTS projects (
    id            TEXT PRIMARY KEY,
    path          TEXT UNIQUE NOT NULL,
    name          TEXT,
    registered_at INTEGER,
    last_seen     INTEGER
);
CREATE INDEX IF NOT EXISTS idx_projects_seen ON projects(last_seen DESC);
"""


def projects_db_connect():
    USER_DATA_DIR.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(PROJECTS_DB))
    conn.executescript(PROJECTS_SCHEMA)
    return conn


def project_id_for(path):
    """Deterministic short id for a path (sha256[:8])."""
    return hashlib.sha256(os.path.realpath(path).encode()).hexdigest()[:8]


def register_project(path):
    """Insert or update the project entry, return its id."""
    if not path:
        return None
    real = os.path.realpath(path)
    pid = project_id_for(real)
    name = os.path.basename(real)
    now = int(time.time())
    try:
        conn = projects_db_connect()
        conn.execute(
            "INSERT INTO projects (id, path, name, registered_at, last_seen) "
            "VALUES (?, ?, ?, ?, ?) "
            "ON CONFLICT(id) DO UPDATE SET last_seen = excluded.last_seen, name = excluded.name",
            (pid, real, name, now, now),
        )
        conn.commit()
        conn.close()
    except Exception:
        pass
    return pid


def list_projects(include_missing=False):
    """Return list of {id, path, name, last_seen, exists}. Newest first."""
    try:
        conn = projects_db_connect()
        rows = conn.execute(
            "SELECT id, path, name, registered_at, last_seen FROM projects "
            "ORDER BY last_seen DESC"
        ).fetchall()
        conn.close()
    except Exception:
        rows = []
    out = []
    for pid, path, name, reg, seen in rows:
        exists = os.path.isdir(path) and os.path.isdir(os.path.join(path, ".git"))
        if include_missing or exists:
            out.append({
                "id": pid, "path": path, "name": name,
                "registered_at": reg, "last_seen": seen, "exists": exists,
            })
    return out


def get_project(project_id):
    try:
        conn = projects_db_connect()
        row = conn.execute(
            "SELECT id, path, name, registered_at, last_seen FROM projects WHERE id = ?",
            (project_id,),
        ).fetchone()
        conn.close()
    except Exception:
        return None
    if not row:
        return None
    return {"id": row[0], "path": row[1], "name": row[2],
            "registered_at": row[3], "last_seen": row[4]}


# ---------------- helpers shared by hooks + UI ----------------

# Files we deliberately keep out of every snapshot — they're per-machine
# state and including them would clobber prompt history on restore.
_DB_EXCLUDE_PATHS = (
    PROJECT_DB_REL,                      # .claude/checkpoints.db
    PROJECT_DB_REL + "-journal",
    PROJECT_DB_REL + "-wal",
    PROJECT_DB_REL + "-shm",
)


def _strip_db_from_index(root, env):
    """After `git add -A` into the temp index, drop the SQLite DB files."""
    subprocess.run(
        ["git", "rm", "--cached", "--ignore-unmatch", "--", *_DB_EXCLUDE_PATHS],
        env=env, capture_output=True, cwd=root,
    )


def _purge_in_tree_db(root):
    """Delete any `<root>/.claude/checkpoints.db*` that surfaced in the
    working tree (and stage that deletion in the index) after restoring an
    older snapshot.

    Modern snapshots strip the DB before commit, but pre-migration trees
    embed it. The live DB lives in USER_DATA_DIR and is untouched by
    read-tree — anything that lands in `.claude/` is stale and should go.
    """
    removed_any = False
    for rel in _DB_EXCLUDE_PATHS:
        try:
            os.unlink(os.path.join(root, rel))
            removed_any = True
        except FileNotFoundError:
            pass
        except Exception:
            pass
    if removed_any:
        # Drop the entries from the index so `git status` doesn't flag them
        # as deleted-against-the-restored-tree.
        subprocess.run(
            ["git", "rm", "--cached", "--ignore-unmatch", "--quiet", "--", *_DB_EXCLUDE_PATHS],
            capture_output=True, cwd=root,
        )


def _remove_untracked_after_restore(root):
    """Delete non-ignored untracked files left over after a read-tree restore.

    `git read-tree --reset -u` only touches files in the index, so any file
    added to the working tree after the target checkpoint (and thus never
    indexed) survives the restore. Snapshots, by contrast, capture untracked
    files via `git add -A`, so users expect a restore to mirror the snapshot
    exactly — including the absence of files added later. The project DB
    files are preserved unconditionally.
    """
    out, _, _ = git("ls-files", "--others", "--exclude-standard", cwd=root)
    keep = set(_DB_EXCLUDE_PATHS)
    for rel in out.splitlines():
        if not rel or rel in keep:
            continue
        try:
            os.unlink(os.path.join(root, rel))
        except (FileNotFoundError, IsADirectoryError, PermissionError):
            pass


def make_snapshot_commit(root, message):
    """Snapshot working tree (incl. untracked, respecting .gitignore) into a
    parentless-or-from-HEAD commit. Live index/worktree untouched.
    Returns commit hash or None."""
    git_dir, _, code = git("rev-parse", "--git-dir", cwd=root)
    if code != 0:
        return None
    git_dir = git_dir.strip()
    if not os.path.isabs(git_dir):
        git_dir = os.path.join(root, git_dir)
    live_index = os.path.join(git_dir, "index")

    tmp = tempfile.NamedTemporaryFile(delete=False, prefix="ckpt-idx-", suffix=".idx")
    tmp.close()
    try:
        if os.path.exists(live_index):
            shutil.copyfile(live_index, tmp.name)
        env = os.environ.copy()
        env["GIT_INDEX_FILE"] = tmp.name
        subprocess.run(["git", "add", "-A"], env=env, capture_output=True, cwd=root)
        _strip_db_from_index(root, env)
        r = subprocess.run(["git", "write-tree"], env=env, capture_output=True, text=True, cwd=root)
        if r.returncode != 0:
            return None
        tree = r.stdout.strip()
        if not tree:
            return None
        head, _, code = git("rev-parse", "HEAD", cwd=root)
        head = head.strip() if code == 0 else ""
        cmd = ["git", "commit-tree", tree, "-m", message]
        if head:
            cmd.extend(["-p", head])
        r = subprocess.run(cmd, capture_output=True, text=True, cwd=root)
        return r.stdout.strip() if r.returncode == 0 else None
    finally:
        try:
            os.unlink(tmp.name)
        except Exception:
            pass


def compute_shortstat(root, ref):
    out, _, _ = git("diff", "--shortstat", f"{ref}^", ref, cwd=root)
    files = ins = dels = 0
    m = re.search(r"(\d+) files? changed", out)
    if m: files = int(m.group(1))
    m = re.search(r"(\d+) insertions?\(\+\)", out)
    if m: ins = int(m.group(1))
    m = re.search(r"(\d+) deletions?\(-\)", out)
    if m: dels = int(m.group(1))
    return files, ins, dels


def list_checkpoints(root):
    """Return list of {id, ref, when, iso, message, stats, source}. Newest first.
    Caches stats in the project's SQLite db on first compute."""
    out, _, _ = git(
        "for-each-ref", f"{REF_NS}/", "--sort=-refname",
        "--format=%(refname)\x1f%(refname:short)\x1f%(authordate:relative)\x1f%(authordate:iso)\x1f%(contents:subject)",
        cwd=root,
    )
    # Per-row metadata cached in SQLite: stats, source tag, starred flag.
    # Pre-existing rows missing these fields render with default styling.
    stats_cache = {}
    source_by_id = {}
    starred_ids = set()
    conn = project_db_connect(root, create=False)
    if conn:
        try:
            for cid, f, i, d, src, st in conn.execute(
                "SELECT id, files_changed, insertions, deletions, source, starred FROM checkpoints"
            ).fetchall():
                if f is not None:
                    stats_cache[cid] = {"files": f or 0, "insertions": i or 0, "deletions": d or 0}
                if src:
                    source_by_id[cid] = src
                if st:
                    starred_ids.add(cid)
        except Exception:
            pass

    rows = []
    to_persist = []
    for line in out.splitlines():
        parts = line.split("\x1f")
        if len(parts) < 5:
            continue
        ref, short, when, iso, subject = parts
        cid = ref.rsplit("/", 1)[-1]
        msg = re.sub(r"^On [^:]+: ", "", subject)
        stats = stats_cache.get(cid)
        if not stats:
            files, ins, dels = compute_shortstat(root, ref)
            stats = {"files": files, "insertions": ins, "deletions": dels}
            to_persist.append((cid, files, ins, dels))
        rows.append({"id": cid, "ref": ref, "when": when, "iso": iso, "message": msg,
                     "stats": stats, "source": source_by_id.get(cid),
                     "starred": cid in starred_ids})

    if conn and to_persist:
        try:
            conn.executemany(
                "INSERT INTO checkpoints (id, files_changed, insertions, deletions) "
                "VALUES (?, ?, ?, ?) "
                "ON CONFLICT(id) DO UPDATE SET "
                "    files_changed = excluded.files_changed, "
                "    insertions    = excluded.insertions, "
                "    deletions     = excluded.deletions",
                to_persist,
            )
            conn.commit()
        except Exception:
            pass
    if conn:
        conn.close()
    return rows


def get_files_for(root, ref):
    out, _, _ = git("diff", "--name-status", f"{ref}^", ref, cwd=root)
    files = []
    for line in out.splitlines():
        parts = line.split("\t")
        if len(parts) >= 2:
            files.append({"status": parts[0], "path": parts[-1]})
    return files


def get_file_diff(root, ref, path):
    out, _, _ = git("diff", f"{ref}^", ref, "--", path, cwd=root)
    return out


def get_prompt_for(root, ckpt_id):
    conn = project_db_connect(root, create=False)
    if not conn:
        return None
    try:
        row = conn.execute("SELECT prompt FROM checkpoints WHERE id = ?", (ckpt_id,)).fetchone()
        conn.close()
        return row[0] if row and row[0] else None
    except Exception:
        return None


def has_trash(root):
    _, _, code = git("rev-parse", "--verify", TRASH_REF, cwd=root)
    return code == 0


def status_for(root):
    branch, _, _ = git("branch", "--show-current", cwd=root)
    return {
        "branch": branch.strip(),
        "has_undo": has_trash(root),
        "count": len(list_checkpoints(root)),
    }


# ---------------- restore operations ----------------

def op_restore_full(root, ref, delete_later=False):
    # Default: hard-reset the working tree to this checkpoint but keep every
    # later checkpoint intact so the user can restore forward.
    # Opt-in (`delete_later=True`): legacy behavior — also remove every
    # checkpoint whose timestamp sorts after the target. The pre-restore
    # safety snapshot is always saved so `ckpt undo` can recover state.
    #
    # The project's SQLite DB lives in USER_DATA_DIR, out of the working
    # tree, so read-tree can't touch it. Pre-migration snapshots embedded
    # `.claude/checkpoints.db` in their tree, though, and a restore of one
    # would materialize that stale copy in the working tree — _purge_in_tree_db
    # cleans it up so the moved-out DB stays the sole source of truth.
    safety = make_snapshot_commit(root, f"pre-restore safety ({time.strftime('%Y-%m-%d %H:%M:%S')})")
    if safety:
        git("update-ref", TRASH_REF, safety, cwd=root)

    _, err, code = git("read-tree", "--reset", "-u", ref, cwd=root)
    if code != 0:
        return {"ok": False, "error": (err or "read-tree failed").strip()}
    _purge_in_tree_db(root)
    _remove_untracked_after_restore(root)

    deleted = 0
    if delete_later:
        out, _, _ = git("for-each-ref", f"{REF_NS}/", "--format=%(refname)", cwd=root)
        target_basename = ref.rsplit("/", 1)[-1]
        for r in out.splitlines():
            if not r.strip():
                continue
            if r.rsplit("/", 1)[-1] > target_basename:
                git("update-ref", "-d", r, cwd=root)
                deleted += 1
        cleanup_orphan_rows(root)

    return {"ok": True, "deleted": deleted, "safety": bool(safety)}


def op_restore_file(root, ref, path):
    if not path:
        return {"ok": False, "error": "missing path"}
    _, err, code = git("checkout", ref, "--", path, cwd=root)
    if code != 0:
        return {"ok": False, "error": err.strip() or "checkout failed"}
    return {"ok": True}


def op_delete(root, ref):
    _, err, code = git("update-ref", "-d", ref, cwd=root)
    if code == 0:
        conn = project_db_connect(root, create=False)
        if conn:
            try:
                conn.execute("DELETE FROM checkpoints WHERE id = ?", (ref.rsplit("/", 1)[-1],))
                conn.commit()
                conn.close()
            except Exception:
                pass
    return {"ok": code == 0, "error": err.strip() if code != 0 else None}


def op_prune(root, n):
    out, _, _ = git("for-each-ref", f"{REF_NS}/", "--sort=-refname", "--format=%(refname)", cwd=root)
    refs = [r for r in out.splitlines() if r.strip()]
    victims = refs[n:]
    for r in victims:
        git("update-ref", "-d", r, cwd=root)
    cleanup_orphan_rows(root)
    return {"ok": True, "deleted": len(victims)}


def op_set_starred(root, ckpt_ids, starred):
    """Set the starred flag on one or more checkpoints. Creates rows for
    ids that don't yet have a DB entry (could happen if the checkpoint was
    made before the column existed and never re-read)."""
    if not ckpt_ids:
        return {"ok": True, "updated": 0}
    val = 1 if starred else 0
    conn = project_db_connect(root)
    try:
        # Make sure a row exists for each id so the UPDATE has something to
        # hit. INSERT OR IGNORE keeps existing rows intact.
        conn.executemany(
            "INSERT OR IGNORE INTO checkpoints(id) VALUES (?)",
            [(cid,) for cid in ckpt_ids],
        )
        placeholders = ",".join("?" * len(ckpt_ids))
        conn.execute(
            f"UPDATE checkpoints SET starred = ? WHERE id IN ({placeholders})",
            (val, *ckpt_ids),
        )
        conn.commit()
    finally:
        conn.close()
    return {"ok": True, "updated": len(ckpt_ids), "starred": bool(starred)}


def op_bulk_delete(root, ckpt_ids):
    """Delete multiple checkpoints. Returns count of refs actually removed
    (skips ids that no longer have a ref)."""
    deleted = 0
    errors = []
    for cid in ckpt_ids:
        r = op_delete(root, f"{REF_NS}/{cid}")
        if r.get("ok"):
            deleted += 1
        elif r.get("error"):
            errors.append(f"{cid}: {r['error']}")
    cleanup_orphan_rows(root)
    return {"ok": True, "deleted": deleted, "errors": errors}


def op_bulk_restore_files(root, ref, paths):
    """Run op_restore_file across many paths in one call. Stops at the
    first hard error; partial successes are reported."""
    restored = []
    errors = []
    for p in paths:
        if not p:
            continue
        r = op_restore_file(root, ref, p)
        if r.get("ok"):
            restored.append(p)
        else:
            errors.append({"path": p, "error": r.get("error") or "restore failed"})
    return {"ok": not errors, "restored": restored, "errors": errors}


def op_clean(root):
    out, _, _ = git("for-each-ref", f"{REF_NS}/", "--format=%(refname)", cwd=root)
    count = 0
    for r in out.splitlines():
        if r.strip():
            git("update-ref", "-d", r, cwd=root)
            count += 1
    git("update-ref", "-d", TRASH_REF, cwd=root)
    conn = project_db_connect(root, create=False)
    if conn:
        try:
            conn.execute("DELETE FROM checkpoints")
            conn.commit()
            conn.close()
        except Exception:
            pass
    return {"ok": True, "deleted": count}


def op_undo(root):
    if not has_trash(root):
        return {"ok": False, "error": "no recent restore to undo"}
    _, err, code = git("read-tree", "--reset", "-u", TRASH_REF, cwd=root)
    if code != 0:
        return {"ok": False, "error": err.strip() or "read-tree failed"}
    _purge_in_tree_db(root)
    _remove_untracked_after_restore(root)
    return {"ok": True}


# ---------------- global search ----------------

# Per-checkpoint cap when searching diffs. A combined diff for a big sweeping
# refactor can easily run into the megabytes; reading the whole thing into
# memory for every checkpoint × every project would make the UI feel laggy.
# 512 KB is more than enough to catch substring matches in any normally-sized
# turn and keeps the worst-case latency bounded.
_SEARCH_DIFF_BYTE_CAP = 512 * 1024
_SEARCH_SNIPPET_BEFORE = 60
_SEARCH_SNIPPET_AFTER  = 120

# Diff text per (root, ref) is immutable — checkpoint refs are write-once.
# We pay the `git diff` cost the first time a checkpoint is searched and
# every subsequent search reuses the cached text. Bounded only by checkpoint
# count; cleared lazily when refs disappear from `list_checkpoints`.
_SEARCH_DIFF_CACHE = {}
_SEARCH_DIFF_CACHE_LOCK = threading.Lock()


def _fetch_diff_cached(root, ref):
    key = (root, ref)
    with _SEARCH_DIFF_CACHE_LOCK:
        cached = _SEARCH_DIFF_CACHE.get(key)
    if cached is not None:
        return cached
    out, _, _ = git("diff", f"{ref}^", ref, cwd=root)
    if len(out) > _SEARCH_DIFF_BYTE_CAP:
        out = out[:_SEARCH_DIFF_BYTE_CAP]
    with _SEARCH_DIFF_CACHE_LOCK:
        _SEARCH_DIFF_CACHE[key] = out
    return out


def _prune_diff_cache(root, live_ckpt_ids):
    """Drop cached diffs for refs that no longer exist in the project."""
    live_refs = {f"{REF_NS}/{cid}" for cid in live_ckpt_ids}
    with _SEARCH_DIFF_CACHE_LOCK:
        stale = [k for k in _SEARCH_DIFF_CACHE
                 if k[0] == root and k[1] not in live_refs]
        for k in stale:
            _SEARCH_DIFF_CACHE.pop(k, None)


def _prompts_for_ckpts(root, ckpt_ids):
    """One SQLite open per project instead of one per checkpoint."""
    if not ckpt_ids:
        return {}
    conn = project_db_connect(root, create=False)
    if not conn:
        return {}
    out = {}
    try:
        # SQLite caps parameter count around 999 by default; chunk to stay clear.
        for i in range(0, len(ckpt_ids), 800):
            chunk = ckpt_ids[i:i + 800]
            placeholders = ",".join("?" * len(chunk))
            for cid, prompt in conn.execute(
                f"SELECT id, prompt FROM checkpoints WHERE id IN ({placeholders})",
                chunk,
            ):
                if prompt:
                    out[cid] = prompt
    except Exception:
        pass
    finally:
        try: conn.close()
        except Exception: pass
    return out


def _snippet(text, match, before=_SEARCH_SNIPPET_BEFORE, after=_SEARCH_SNIPPET_AFTER):
    if not text:
        return ""
    if match is None:
        return text[: before + after]
    s = max(0, match.start() - before)
    e = min(len(text), match.end() + after)
    return ("…" if s > 0 else "") + text[s:e] + ("…" if e < len(text) else "")


def _split_diff_by_file(diff_text):
    """Yield (path, body) for each file in a combined `git diff` output."""
    cur_path, cur_lines, header_done = None, [], False
    for line in diff_text.splitlines():
        m = re.match(r"^diff --git a/(.*) b/(.*)$", line)
        if m:
            if cur_path is not None:
                yield cur_path, "\n".join(cur_lines)
            cur_path = m.group(2)
            cur_lines = []
            header_done = False
            continue
        # Skip the per-file header noise so snippet positions align with
        # what the diff viewer actually shows.
        if not header_done and re.match(r"^(index |new file|deleted file|rename |similarity |Binary |--- |\+\+\+ )", line):
            continue
        header_done = True
        cur_lines.append(line)
    if cur_path is not None:
        yield cur_path, "\n".join(cur_lines)


def op_search(query, *, regex=False, scope=None, project_ids=None,
              since=None, until=None, mode="include", max_results=200):
    """Search across every registered project's checkpoints.

    Returns matches in three flavors: `project` (project name/path hit),
    `checkpoint` (commit-message / prompt hit), and `diff` (a hit inside a
    file's diff for some checkpoint). `mode="exclude"` flips the predicate
    so a hit means *no match* in that scope — useful for "checkpoints that
    don't mention X".

    Date filters use the checkpoint id (`YYYYMMDD-HHMMSS`), which sorts
    chronologically. `since`/`until` are accepted as ISO-ish strings; only
    the digits are kept so callers can pass `2026-05-20` or
    `2026-05-20T10:00`.
    """
    q = query or ""
    if not q:
        return {"ok": False, "error": "empty query"}

    try:
        flags = 0 if regex else re.IGNORECASE
        pattern = re.compile(q if regex else re.escape(q), flags)
    except re.error as e:
        return {"ok": False, "error": f"invalid regex: {e}"}

    scope = scope or {}
    want_projects    = scope.get("projects",    True)
    want_checkpoints = scope.get("checkpoints", True)
    want_diffs       = scope.get("diffs",       True)
    invert           = (mode == "exclude")
    pid_filter       = set(project_ids) if project_ids else None

    def _norm_date(s):
        if not s:
            return None
        digits = re.sub(r"\D", "", str(s))
        return digits or None
    since_n = _norm_date(since)
    until_n = _norm_date(until)

    def _in_range(ckpt_id):
        # `ckpt_id` is `YYYYMMDD-HHMMSS`; drop the dash to get a sortable string.
        cid = re.sub(r"\D", "", ckpt_id)
        if since_n and cid < since_n[: len(cid)]:
            return False
        if until_n:
            tail = cid[: len(until_n)]
            if tail > until_n:
                return False
        return True

    matches = []
    stats = {"projects_searched": 0, "checkpoints_searched": 0,
             "diffs_searched": 0, "match_count": 0}

    def _push(item):
        matches.append(item)
        stats["match_count"] += 1
        return len(matches) >= max_results

    # One executor for the whole search. Diff fetching is `git diff`-bound,
    # which is IO/process-startup heavy — running 8 in parallel cuts wall
    # time roughly to (N / 8) × per-call cost instead of N × per-call.
    pool = ThreadPoolExecutor(max_workers=8)
    try:
        for proj in list_projects(include_missing=False):
            if pid_filter and proj["id"] not in pid_filter:
                continue
            stats["projects_searched"] += 1
            root = proj["path"]
            pname = proj.get("name") or os.path.basename(proj["path"])

            if want_projects:
                hay = f"{pname}\n{proj['path']}"
                m = pattern.search(hay)
                if bool(m) != invert:
                    if _push({
                        "kind": "project",
                        "project_id": proj["id"],
                        "project_name": pname,
                        "project_path": proj["path"],
                        "snippet": _snippet(hay, m) if m else hay,
                    }):
                        return {"ok": True, "matches": matches, "stats": stats}

            if not (want_checkpoints or want_diffs):
                continue

            try:
                all_ckpts = list_checkpoints(root)
            except Exception:
                all_ckpts = []
            _prune_diff_cache(root, [c["id"] for c in all_ckpts])
            ckpts = [c for c in all_ckpts if _in_range(c["id"])]
            stats["checkpoints_searched"] += len(ckpts)

            # Pass 1 — checkpoint message + prompt (cheap, sequential).
            if want_checkpoints:
                prompts = _prompts_for_ckpts(root, [c["id"] for c in ckpts])
                for c in ckpts:
                    hay_parts = [c.get("message") or ""]
                    p = prompts.get(c["id"])
                    if p:
                        hay_parts.append(p)
                    hay = "\n".join(hay_parts)
                    m = pattern.search(hay)
                    if bool(m) != invert:
                        if _push({
                            "kind": "checkpoint",
                            "project_id": proj["id"],
                            "project_name": pname,
                            "checkpoint_id": c["id"],
                            "checkpoint_message": c.get("message"),
                            "when": c.get("when"),
                            "iso": c.get("iso"),
                            "snippet": _snippet(hay, m) if m else hay,
                        }):
                            return {"ok": True, "matches": matches, "stats": stats}

            # Pass 2 — diff content (one `git diff` per checkpoint on the
            # first search, cached forever after — refs are immutable. The
            # first call still runs them in parallel because subprocess
            # startup dominates each one.).
            if want_diffs and ckpts:
                stats["diffs_searched"] += len(ckpts)
                def _fetch(c, _root=root):
                    ref = c.get("ref") or f"{REF_NS}/{c['id']}"
                    return c, _fetch_diff_cached(_root, ref)
                for c, diff_out in pool.map(_fetch, ckpts):
                    for path, body in _split_diff_by_file(diff_out):
                        m = pattern.search(body)
                        if bool(m) != invert:
                            snippet = _snippet(body, m) if m else body[:200]
                            if _push({
                                "kind": "diff",
                                "project_id": proj["id"],
                                "project_name": pname,
                                "checkpoint_id": c["id"],
                                "when": c.get("when"),
                                "iso": c.get("iso"),
                                "file_path": path,
                                "snippet": snippet,
                            }):
                                return {"ok": True, "matches": matches, "stats": stats}
    finally:
        pool.shutdown(wait=False, cancel_futures=True)

    return {"ok": True, "matches": matches, "stats": stats}


def cleanup_orphan_rows(root):
    """Delete SQLite rows for checkpoint ids whose refs no longer exist."""
    conn = project_db_connect(root, create=False)
    if not conn:
        return
    try:
        out, _, _ = git("for-each-ref", f"{REF_NS}/", "--format=%(refname)", cwd=root)
        live = {l.rsplit("/", 1)[-1] for l in out.splitlines() if l.strip()}
        ids = [r[0] for r in conn.execute("SELECT id FROM checkpoints").fetchall()]
        for cid in ids:
            if cid not in live:
                conn.execute("DELETE FROM checkpoints WHERE id = ?", (cid,))
        conn.commit()
        conn.close()
    except Exception:
        pass


# ---------------- hooks ----------------

def _normalize_source(value):
    """Map a free-text source to one of KNOWN_SOURCES, falling back to the
    literal lower-cased value (truncated to 32 chars) so unknown agents
    still get a stable tag — the UI just renders them with a neutral dot."""
    s = (value or "").strip().lower()
    if not s:
        return "claude"
    if s in KNOWN_SOURCES:
        return s
    return s[:32]


def hook_save_prompt(source="claude"):
    """UserPromptSubmit hook: persist the full prompt into the project's db,
    and register the project in the per-machine projects index."""
    try:
        data = json.load(sys.stdin)
    except Exception:
        return
    sid = (data.get("session_id") or "").strip()
    prompt = (data.get("prompt") or "").strip()
    cwd = data.get("cwd") or claude_project_dir()
    # Prompts are tagged solely by the caller's --source flag (Codex and
    # Claude don't put a source field in the payload). The DB schema for
    # prompts doesn't currently carry source — it's only used to fetch the
    # latest prompt for the active session, and the checkpoint row itself
    # carries the source — so we just persist as-is.
    if not sid or not prompt:
        return
    if not is_git_repo(cwd):
        return
    root = project_root(cwd)
    register_project(root)
    conn = project_db_connect(root)
    try:
        conn.execute(
            "INSERT OR REPLACE INTO prompts(session_id, submitted_at, prompt) VALUES (?, ?, ?)",
            (sid, int(time.time()), prompt),
        )
        # Cull rows older than 30 days
        conn.execute(
            "DELETE FROM prompts WHERE submitted_at < ?",
            (int(time.time()) - 30 * 86400,),
        )
        conn.commit()
    finally:
        conn.close()


def hook_checkpoint(source="claude"):
    """Stop hook: snapshot the working tree and record the checkpoint."""
    try:
        data = json.load(sys.stdin)
    except Exception:
        data = {}
    sid = (data.get("session_id") or "").strip()
    cwd = data.get("cwd") or claude_project_dir()
    if not is_git_repo(cwd):
        return
    root = project_root(cwd)
    register_project(root)
    source = _normalize_source(source)

    # Fetch the latest prompt for this session, if any.
    prompt = None
    if sid:
        conn = project_db_connect(root, create=False)
        if conn:
            try:
                row = conn.execute(
                    "SELECT prompt FROM prompts WHERE session_id = ? "
                    "ORDER BY submitted_at DESC LIMIT 1",
                    (sid,),
                ).fetchone()
                prompt = row[0] if row else None
                conn.close()
            except Exception:
                pass

    msg = (prompt.splitlines()[0] if prompt and prompt.strip() else None) or "(turn)"

    # Build the snapshot
    git_dir, _, _ = git("rev-parse", "--git-dir", cwd=root)
    git_dir = git_dir.strip()
    if not os.path.isabs(git_dir):
        git_dir = os.path.join(root, git_dir)
    live_index = os.path.join(git_dir, "index")

    tmp = tempfile.NamedTemporaryFile(delete=False, prefix="ckpt-idx-", suffix=".idx")
    tmp.close()
    try:
        if os.path.exists(live_index):
            shutil.copyfile(live_index, tmp.name)
        env = os.environ.copy()
        env["GIT_INDEX_FILE"] = tmp.name
        subprocess.run(["git", "add", "-A"], env=env, capture_output=True, cwd=root)
        _strip_db_from_index(root, env)
        r = subprocess.run(["git", "write-tree"], env=env, capture_output=True, text=True, cwd=root)
        if r.returncode != 0:
            return
        tree = r.stdout.strip()
        if not tree:
            return
    finally:
        try:
            os.unlink(tmp.name)
        except Exception:
            pass

    # Skip if identical to the most recent checkpoint (or HEAD if none).
    latest_r = subprocess.run(
        ["git", "for-each-ref", f"{REF_NS}/", "--sort=-refname", "--format=%(refname)", "--count=1"],
        capture_output=True, text=True, cwd=root,
    )
    latest = latest_r.stdout.strip()
    if latest:
        lt = subprocess.run(["git", "rev-parse", f"{latest}^{{tree}}"], capture_output=True, text=True, cwd=root).stdout.strip()
        if tree == lt:
            return
    else:
        ht_r = subprocess.run(["git", "rev-parse", "HEAD^{tree}"], capture_output=True, text=True, cwd=root)
        if tree == ht_r.stdout.strip():
            return

    head, _, _ = git("rev-parse", "HEAD", cwd=root)
    head = head.strip()
    cmd = ["git", "commit-tree", tree, "-m", msg]
    if head:
        cmd.extend(["-p", head])
    commit = subprocess.run(cmd, capture_output=True, text=True, cwd=root).stdout.strip()
    if not commit:
        return

    ckpt_id = time.strftime("%Y%m%d-%H%M%S")
    ref = f"{REF_NS}/{ckpt_id}"
    _, _, code = git("update-ref", ref, commit, cwd=root)
    if code != 0:
        return

    # Compute shortstat
    files, ins, dels = compute_shortstat(root, ref)

    # Store in project db
    conn = project_db_connect(root)
    try:
        conn.execute(
            "INSERT OR REPLACE INTO checkpoints"
            "(id, session_id, prompt, created_at, files_changed, insertions, deletions, source) "
            "VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
            (ckpt_id, sid or None, prompt, int(time.time()), files, ins, dels, source),
        )
        conn.commit()
    finally:
        conn.close()

    # Prune git refs to last 100
    out, _, _ = git("for-each-ref", f"{REF_NS}/", "--sort=-refname", "--format=%(refname)", cwd=root)
    refs = [r.strip() for r in out.splitlines() if r.strip()]
    for old in refs[100:]:
        git("update-ref", "-d", old, cwd=root)
    cleanup_orphan_rows(root)


