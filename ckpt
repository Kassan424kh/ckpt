def _mcp_project_root(project_id):
    """Resolve a project_id to an existing on-disk path, or raise."""
    if not project_id:
        raise ValueError("project_id is required")
    p = get_project(project_id)
    if not p:
        raise ValueError(f"project not found: {project_id}")
    path = p["path"]
    if not os.path.isdir(path):
        raise ValueError(f"project path no longer exists: {path}")
    return path


def _mcp_resolve_ref(root, checkpoint_id):
    """Accept timestamp ids, 'latest'/'last'/'-N', partial substrings, or full refs."""
    if not checkpoint_id:
        raise ValueError("checkpoint_id is required")
    ref = _resolve_ref(root, checkpoint_id)
    if not ref:
        raise ValueError(f"checkpoint not found: {checkpoint_id}")
    return ref


def mcp_dispatch_tool(name, args):
    """Run a single MCP tool. Returns a plain dict (encoded by the caller).
    Raises ValueError on bad input, RuntimeError on tool failure."""
    args = args or {}

    if name == "list_projects":
        return {"projects": list_projects()}

    if name not in {t["name"] for t in MCP_TOOLS}:
        raise ValueError(f"unknown tool: {name}")

    root = _mcp_project_root(args.get("project_id"))

    if name == "get_project_status":
        return status_for(root)

    if name == "list_checkpoints":
        rows = list_checkpoints(root)
        limit = args.get("limit")
        if isinstance(limit, int) and limit > 0:
            rows = rows[:limit]
        return {"checkpoints": rows}

    ref = _mcp_resolve_ref(root, args.get("checkpoint_id"))
    ckpt_id = ref.rsplit("/", 1)[-1]

    if name == "get_checkpoint_prompt":
        return {"checkpoint_id": ckpt_id, "prompt": get_prompt_for(root, ckpt_id)}

    if name == "get_checkpoint_files":
        return {"checkpoint_id": ckpt_id, "files": get_files_for(root, ref)}

    if name == "get_checkpoint_diff":
        path = args.get("path")
        if path:
            return {"checkpoint_id": ckpt_id, "path": path,
                    "diff": get_file_diff(root, ref, path)}
        out, _, _ = git("diff", f"{ref}^", ref, cwd=root)
        return {"checkpoint_id": ckpt_id, "diff": out}

    if name == "get_file_at_checkpoint":
        path = args.get("path")
        if not path:
            raise ValueError("path is required")
        out, err, code = git("show", f"{ref}:{path}", cwd=root)
        if code != 0:
            raise RuntimeError((err or "git show failed").strip())
        return {"checkpoint_id": ckpt_id, "path": path, "content": out}

    if name == "restore_checkpoint":
        path = args.get("path")
        if path:
            return op_restore_file(root, ref, path)
        return op_restore_full(root, ref, bool(args.get("delete_later", False)))

    if name == "undo_restore":
        return op_undo(root)

    if name == "delete_checkpoint":
        return op_delete(root, ref)

    if name == "prune_checkpoints":
        keep = args.get("keep")
        if not isinstance(keep, int) or keep < 0:
            raise ValueError("keep must be a non-negative integer")
        return op_prune(root, keep)

    raise ValueError(f"unknown tool: {name}")


def _mcp_log(msg):
    """Server-side logging — goes to stderr so it doesn't corrupt the protocol stream."""
    try:
        print(f"[ckpt mcp] {msg}", file=sys.stderr, flush=True)
    except Exception:
        pass


def mcp_serve():
    """Run the stdio MCP loop. Reads one JSON-RPC message per line of stdin,
    writes one JSON-RPC message per line of stdout."""
    server_info = {"name": "ckpt", "version": installed_version() or "dev"}

    def send(obj):
        sys.stdout.write(json.dumps(obj, ensure_ascii=False) + "\n")
        sys.stdout.flush()

    def respond(req_id, result):
        send({"jsonrpc": "2.0", "id": req_id, "result": result})

    def err(req_id, code, message, data=None):
        e = {"code": code, "message": message}
        if data is not None:
            e["data"] = data
        send({"jsonrpc": "2.0", "id": req_id, "error": e})

    for raw in sys.stdin:
        line = raw.strip()
        if not line:
            continue
        try:
            msg = json.loads(line)
        except Exception as e:
            _mcp_log(f"parse error: {e}")
            continue
        if not isinstance(msg, dict):
            continue

        method = msg.get("method") or ""
        params = msg.get("params") or {}
        req_id = msg.get("id")
        is_notification = req_id is None

        if method == "initialize":
            client_v = (params.get("protocolVersion") or "").strip()
            respond(req_id, {
                "protocolVersion": client_v or MCP_PROTOCOL_VERSION,
                "capabilities": {"tools": {"listChanged": False}},
                "serverInfo": server_info,
            })
            continue

        if method in ("notifications/initialized", "notifications/cancelled"):
            continue  # notifications: no response

        if method == "ping":
            if not is_notification:
                respond(req_id, {})
            continue

        if method == "tools/list":
            respond(req_id, {"tools": MCP_TOOLS})
            continue

        if method == "tools/call":
            name = params.get("name") or ""
            args = params.get("arguments") or {}
            try:
                result = mcp_dispatch_tool(name, args)
                respond(req_id, {
                    "content": [{"type": "text", "text": json.dumps(result, indent=2, ensure_ascii=False)}],
                    "isError": False,
                })
            except Exception as e:
                respond(req_id, {
                    "content": [{"type": "text", "text": f"{type(e).__name__}: {e}"}],
                    "isError": True,
                })
            continue

        if method == "shutdown":
            if not is_notification:
                respond(req_id, {})
            return

        if not is_notification:
            err(req_id, -32601, f"Method not found: {method}")


def cmd_mcp(_args):
    try:
        mcp_serve()
    except (KeyboardInterrupt, BrokenPipeError):
        pass


# ---------------- main dispatch ----------------

def main():
    parser = argparse.ArgumentParser(prog="ckpt", description="Per-turn git-ref checkpoints for Claude Code and Codex CLI.")
    parser.add_argument("--hook", choices=["save-prompt", "checkpoint"],
                        help=argparse.SUPPRESS)
    parser.add_argument("--source", default="claude",
                        help=argparse.SUPPRESS)  # caller tag: claude | codex | <other>
    sub = parser.add_subparsers(dest="cmd")

    sub.add_parser("list", help="List checkpoints").set_defaults(func=lambda a: cmd_list())
    sub.add_parser("ls",   help=argparse.SUPPRESS).set_defaults(func=lambda a: cmd_list())

    p = sub.add_parser("show", help="Show a checkpoint's diff")
    p.add_argument("ref")
    p.set_defaults(func=cmd_show)

    p = sub.add_parser("restore", help="Restore a checkpoint")
    p.add_argument("ref", nargs="?", default=None)
    p.add_argument("path", nargs="?", default=None)
    p.set_defaults(func=cmd_restore)

    sub.add_parser("undo",   help="Roll back the last restore").set_defaults(func=lambda a: cmd_undo())
    sub.add_parser("latest", help="Show newest checkpoint").set_defaults(func=lambda a: cmd_latest())
    sub.add_parser("clean",  help="Delete all checkpoints").set_defaults(func=lambda a: cmd_clean())

    p = sub.add_parser("delete", help="Delete one checkpoint"); p.add_argument("ref"); p.set_defaults(func=cmd_delete)
    sub.add_parser("rm", help=argparse.SUPPRESS).set_defaults(func=lambda a: cmd_delete(a)) if False else None  # placeholder

    p = sub.add_parser("prune", help="Keep only N newest"); p.add_argument("n", type=int); p.set_defaults(func=cmd_prune)

    p = sub.add_parser("ui", help="Launch the web UI")
    p.add_argument("--port", type=int, default=None)
    p.add_argument("--no-open", action="store_true")
    p.set_defaults(func=cmd_ui)

    sub.add_parser("mcp", help="Run as a stdio MCP server").set_defaults(func=cmd_mcp)

    sub.add_parser("projects", help="List known projects").set_defaults(func=lambda a: cmd_projects())
    sub.add_parser("migrate",  help="Migrate old in-repo .claude/ setup to ckpt").set_defaults(func=lambda a: cmd_migrate())

    args = parser.parse_args()

    if args.hook == "save-prompt":
        hook_save_prompt(source=args.source); return
    if args.hook == "checkpoint":
        hook_checkpoint(source=args.source); return

    if not args.cmd:
        parser.print_help()
        return
    args.func(args)


if __name__ == "__main__":
    main()
