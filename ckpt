def find_free_port(start=8765, limit=50):
    for p in range(start, start + limit):
        try:
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.bind(("127.0.0.1", p))
                return p
        except OSError:
            continue
    raise RuntimeError(f"no free port in {start}..{start+limit}")


class UIHandler(http.server.BaseHTTPRequestHandler):
    def log_message(self, *args):
        pass

    def _send_json(self, obj, status=200):
        body = json.dumps(obj).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def _send_text(self, text, status=200, ctype="text/plain; charset=utf-8"):
        body = text.encode() if isinstance(text, str) else text
        self.send_response(status)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def _read_json(self):
        length = int(self.headers.get("Content-Length", 0))
        if not length:
            return {}
        try:
            return json.loads(self.rfile.read(length))
        except Exception:
            return {}

    def _project_root_for(self, pid):
        p = get_project(pid)
        if not p:
            return None
        path = p["path"]
        if not os.path.isdir(path):
            return None
        return path

    def do_GET(self):
        u = urlparse(self.path)
        p = u.path
        q = parse_qs(u.query)
        try:
            if p == "/" or p == "/index.html":
                self._serve_file(WEB_DIR / "index.html", "text/html; charset=utf-8")
                return
            if p == "/app.js":
                self._serve_file(WEB_DIR / "app.js", "application/javascript; charset=utf-8")
                return
            if p == "/styles.css":
                self._serve_file(WEB_DIR / "styles.css", "text/css; charset=utf-8")
                return
            if p == "/api/projects":
                self._send_json(list_projects())
                return
            if p == "/api/version":
                self._send_json({"installed": installed_version()})
                return
            if p == "/api/updates":
                self._send_json(check_for_updates())
                return

            m = re.match(r"^/api/projects/([^/]+)/status$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"error": "project not found"}, status=404)
                self._send_json(status_for(root)); return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"error": "project not found"}, status=404)
                self._send_json(list_checkpoints(root)); return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints/([^/]+)/prompt$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"error": "project not found"}, status=404)
                self._send_json({"prompt": get_prompt_for(root, m.group(2))}); return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints/([^/]+)/files$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"error": "project not found"}, status=404)
                ref = f"{REF_NS}/{m.group(2)}"
                self._send_json(get_files_for(root, ref)); return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints/([^/]+)/file-diff$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_text("", 404)
                ref = f"{REF_NS}/{m.group(2)}"
                path = unquote((q.get("path") or [""])[0])
                self._send_text(get_file_diff(root, ref, path)); return

            self.send_error(404)
        except Exception as e:
            self._send_json({"error": str(e)}, status=500)

    def do_POST(self):
        u = urlparse(self.path)
        p = u.path
        try:
            if p == "/api/update":
                self._send_json(op_self_update()); return

            if p == "/api/search":
                data = self._read_json()
                try:
                    max_results = max(1, min(1000, int(data.get("max_results", 200))))
                except Exception:
                    max_results = 200
                self._send_json(op_search(
                    query=str(data.get("query") or ""),
                    regex=bool(data.get("regex", False)),
                    scope=data.get("scope") or None,
                    project_ids=data.get("project_ids") or None,
                    since=data.get("since") or None,
                    until=data.get("until") or None,
                    mode=str(data.get("mode") or "include"),
                    max_results=max_results,
                ))
                return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints/([^/]+)/restore$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"ok": False, "error": "project not found"}, status=404)
                ref = f"{REF_NS}/{m.group(2)}"
                data = self._read_json()
                self._send_json(op_restore_full(root, ref, bool(data.get("delete_later", False)))); return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints/([^/]+)/restore-file$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"ok": False, "error": "project not found"}, status=404)
                ref = f"{REF_NS}/{m.group(2)}"
                data = self._read_json()
                self._send_json(op_restore_file(root, ref, data.get("path", ""))); return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints/([^/]+)/delete$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"ok": False, "error": "project not found"}, status=404)
                ref = f"{REF_NS}/{m.group(2)}"
                self._send_json(op_delete(root, ref)); return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints/([^/]+)/star$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"ok": False, "error": "project not found"}, status=404)
                data = self._read_json()
                self._send_json(op_set_starred(root, [m.group(2)], bool(data.get("starred", True)))); return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints/bulk-star$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"ok": False, "error": "project not found"}, status=404)
                data = self._read_json()
                ids = [str(i) for i in (data.get("ids") or []) if i]
                self._send_json(op_set_starred(root, ids, bool(data.get("starred", True)))); return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints/bulk-delete$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"ok": False, "error": "project not found"}, status=404)
                data = self._read_json()
                ids = [str(i) for i in (data.get("ids") or []) if i]
                self._send_json(op_bulk_delete(root, ids)); return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints/([^/]+)/bulk-restore-files$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"ok": False, "error": "project not found"}, status=404)
                ref = f"{REF_NS}/{m.group(2)}"
                data = self._read_json()
                paths = [str(p_) for p_ in (data.get("paths") or []) if p_]
                self._send_json(op_bulk_restore_files(root, ref, paths)); return

            m = re.match(r"^/api/projects/([^/]+)/prune$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"ok": False, "error": "project not found"}, status=404)
                data = self._read_json()
                try:
                    n = int(data.get("n", -1))
                except Exception:
                    n = -1
                if n < 0:
                    return self._send_json({"ok": False, "error": "n must be a non-negative integer"})
                self._send_json(op_prune(root, n)); return

            m = re.match(r"^/api/projects/([^/]+)/clean$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"ok": False, "error": "project not found"}, status=404)
                self._send_json(op_clean(root)); return

            m = re.match(r"^/api/projects/([^/]+)/undo$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"ok": False, "error": "project not found"}, status=404)
                self._send_json(op_undo(root)); return

            self.send_error(404)
        except Exception as e:
            self._send_json({"ok": False, "error": str(e)}, status=500)

    def _serve_file(self, path, ctype):
        if not path.exists():
            self.send_error(404)
            return
        self._send_text(path.read_bytes(), 200, ctype)


def cmd_ui(args):
    if not WEB_DIR.exists() or not (WEB_DIR / "index.html").exists():
        die(f"web UI not installed at {WEB_DIR}\n"
            f"run the installer or copy web/ from the source tree.")
    # Register current project (best-effort) so it shows up in the picker.
    if is_git_repo():
        register_project(project_root())
    global _running_server, _running_ui_port
    port = args.port or find_free_port()
    server = http.server.ThreadingHTTPServer(("127.0.0.1", port), UIHandler)
    _running_server  = server
    _running_ui_port = port
    url = f"http://127.0.0.1:{port}"
    print(f"ckpt UI: {url}")
    print(f"  data dir: {USER_DATA_DIR}")
    print(f"  Ctrl+C to stop")
    if not args.no_open:
        threading.Timer(0.3, lambda: webbrowser.open(url)).start()
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nstopping…")
        server.shutdown()
    finally:
        _running_server  = None
        _running_ui_port = None


