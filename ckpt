def cmd_migrate():
    """Move a project from the old in-repo .claude/ setup to the system-wide ckpt."""
    root = project_root()
    if not is_git_repo(root):
        die("not a git repository")

    print(f"migrating {root}")
    pid = register_project(root)
    print(f"  registered as project {pid}")

    legacy = [
        ".claude/hooks/save-prompt.sh",
        ".claude/hooks/checkpoint.sh",
        ".claude/checkpoint.sh",
        ".claude/checkpoint-ui.py",
        ".claude/CHECKPOINTS.md",
    ]
    removed = 0
    for rel in legacy:
        p = Path(root) / rel
        if p.exists():
            p.unlink()
            removed += 1
            print(f"  removed: {rel}")

    hooks_dir = Path(root) / ".claude/hooks"
    if hooks_dir.exists() and not any(hooks_dir.iterdir()):
        hooks_dir.rmdir()
        print("  removed: .claude/hooks/")

    settings_path = Path(root) / ".claude/settings.json"
    if settings_path.exists():
        try:
            data = json.loads(settings_path.read_text())
        except Exception:
            data = {}
        if "hooks" in data:
            for event in ("UserPromptSubmit", "Stop"):
                if event in data["hooks"]:
                    kept = []
                    for entry in data["hooks"][event]:
                        new_hooks = [h for h in entry.get("hooks", [])
                                     if "checkpoint.sh" not in h.get("command", "")
                                     and "save-prompt.sh" not in h.get("command", "")]
                        if new_hooks:
                            entry["hooks"] = new_hooks
                            kept.append(entry)
                    if kept:
                        data["hooks"][event] = kept
                    else:
                        del data["hooks"][event]
            if not data["hooks"]:
                del data["hooks"]
            settings_path.write_text(json.dumps(data, indent=2) + "\n")
            print("  cleaned: .claude/settings.json (hooks block)")

    print("  kept:    .claude/checkpoints.db (your data)")
    print("  kept:    refs/claude-checkpoints/* (your snapshots)")
    print()
    print("Migration done. The global hook in ~/.claude/settings.json now handles this project.")


# ---------------- UI server ----------------

def find_free_port(start=8765, limit=50):
    for p in range(start, start + limit):
        try:
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.bind(("127.0.0.1", p))
                return p
        except OSError:
            continue
    raise RuntimeError(f"no free port in {start}..{start+limit}")


class UIHandler(http.server.BaseHTTPRequestHandler):
    def log_message(self, *args):
        pass

    def _send_json(self, obj, status=200):
        body = json.dumps(obj).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def _send_text(self, text, status=200, ctype="text/plain; charset=utf-8"):
        body = text.encode() if isinstance(text, str) else text
        self.send_response(status)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def _read_json(self):
        length = int(self.headers.get("Content-Length", 0))
        if not length:
            return {}
        try:
            return json.loads(self.rfile.read(length))
        except Exception:
            return {}

    def _project_root_for(self, pid):
        p = get_project(pid)
        if not p:
            return None
        path = p["path"]
        if not os.path.isdir(path):
            return None
        return path

    def do_GET(self):
        u = urlparse(self.path)
        p = u.path
        q = parse_qs(u.query)
        try:
            if p == "/" or p == "/index.html":
                self._serve_file(WEB_DIR / "index.html", "text/html; charset=utf-8")
                return
            if p == "/app.js":
                self._serve_file(WEB_DIR / "app.js", "application/javascript; charset=utf-8")
                return
            if p == "/styles.css":
                self._serve_file(WEB_DIR / "styles.css", "text/css; charset=utf-8")
                return
            if p == "/api/projects":
                self._send_json(list_projects())
                return

            m = re.match(r"^/api/projects/([^/]+)/status$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"error": "project not found"}, status=404)
                self._send_json(status_for(root)); return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"error": "project not found"}, status=404)
                self._send_json(list_checkpoints(root)); return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints/([^/]+)/prompt$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"error": "project not found"}, status=404)
                self._send_json({"prompt": get_prompt_for(root, m.group(2))}); return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints/([^/]+)/files$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"error": "project not found"}, status=404)
                ref = f"{REF_NS}/{m.group(2)}"
                self._send_json(get_files_for(root, ref)); return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints/([^/]+)/file-diff$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_text("", 404)
                ref = f"{REF_NS}/{m.group(2)}"
                path = unquote((q.get("path") or [""])[0])
                self._send_text(get_file_diff(root, ref, path)); return

            self.send_error(404)
        except Exception as e:
            self._send_json({"error": str(e)}, status=500)

    def do_POST(self):
        u = urlparse(self.path)
        p = u.path
        try:
            m = re.match(r"^/api/projects/([^/]+)/checkpoints/([^/]+)/restore$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"ok": False, "error": "project not found"}, status=404)
                ref = f"{REF_NS}/{m.group(2)}"
                self._send_json(op_restore_full(root, ref)); return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints/([^/]+)/restore-file$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"ok": False, "error": "project not found"}, status=404)
                ref = f"{REF_NS}/{m.group(2)}"
                data = self._read_json()
                self._send_json(op_restore_file(root, ref, data.get("path", ""))); return

            m = re.match(r"^/api/projects/([^/]+)/checkpoints/([^/]+)/delete$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"ok": False, "error": "project not found"}, status=404)
                ref = f"{REF_NS}/{m.group(2)}"
                self._send_json(op_delete(root, ref)); return

            m = re.match(r"^/api/projects/([^/]+)/prune$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"ok": False, "error": "project not found"}, status=404)
                data = self._read_json()
                try:
                    n = int(data.get("n", -1))
                except Exception:
                    n = -1
                if n < 0:
                    return self._send_json({"ok": False, "error": "n must be a non-negative integer"})
                self._send_json(op_prune(root, n)); return

            m = re.match(r"^/api/projects/([^/]+)/clean$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"ok": False, "error": "project not found"}, status=404)
                self._send_json(op_clean(root)); return

            m = re.match(r"^/api/projects/([^/]+)/undo$", p)
            if m:
                root = self._project_root_for(m.group(1))
                if not root: return self._send_json({"ok": False, "error": "project not found"}, status=404)
                self._send_json(op_undo(root)); return

            self.send_error(404)
        except Exception as e:
            self._send_json({"ok": False, "error": str(e)}, status=500)

    def _serve_file(self, path, ctype):
        if not path.exists():
            self.send_error(404)
            return
        self._send_text(path.read_bytes(), 200, ctype)


def cmd_ui(args):
    if not WEB_DIR.exists() or not (WEB_DIR / "index.html").exists():
        die(f"web UI not installed at {WEB_DIR}\n"
            f"run the installer or copy web/ from the source tree.")
    # Register current project (best-effort) so it shows up in the picker.
    if is_git_repo():
        register_project(project_root())
    port = args.port or find_free_port()
    server = http.server.ThreadingHTTPServer(("127.0.0.1", port), UIHandler)
    url = f"http://127.0.0.1:{port}"
    print(f"ckpt UI: {url}")
    print(f"  data dir: {USER_DATA_DIR}")
    print(f"  Ctrl+C to stop")
    if not args.no_open:
        threading.Timer(0.3, lambda: webbrowser.open(url)).start()
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nstopping…")
        server.shutdown()


# ---------------- main dispatch ----------------

def main():
    parser = argparse.ArgumentParser(prog="ckpt", description="Per-turn git-ref checkpoints for Claude Code.")
    parser.add_argument("--hook", choices=["save-prompt", "checkpoint"],
                        help=argparse.SUPPRESS)
    sub = parser.add_subparsers(dest="cmd")

    sub.add_parser("list", help="List checkpoints").set_defaults(func=lambda a: cmd_list())
    sub.add_parser("ls",   help=argparse.SUPPRESS).set_defaults(func=lambda a: cmd_list())

    p = sub.add_parser("show", help="Show a checkpoint's diff")
    p.add_argument("ref")
    p.set_defaults(func=cmd_show)

    p = sub.add_parser("restore", help="Restore a checkpoint")
    p.add_argument("ref", nargs="?", default=None)
    p.add_argument("path", nargs="?", default=None)
    p.set_defaults(func=cmd_restore)

    sub.add_parser("undo",   help="Roll back the last restore").set_defaults(func=lambda a: cmd_undo())
    sub.add_parser("latest", help="Show newest checkpoint").set_defaults(func=lambda a: cmd_latest())
    sub.add_parser("clean",  help="Delete all checkpoints").set_defaults(func=lambda a: cmd_clean())

    p = sub.add_parser("delete", help="Delete one checkpoint"); p.add_argument("ref"); p.set_defaults(func=cmd_delete)
    sub.add_parser("rm", help=argparse.SUPPRESS).set_defaults(func=lambda a: cmd_delete(a)) if False else None  # placeholder

    p = sub.add_parser("prune", help="Keep only N newest"); p.add_argument("n", type=int); p.set_defaults(func=cmd_prune)

    p = sub.add_parser("ui", help="Launch the web UI")
    p.add_argument("--port", type=int, default=None)
    p.add_argument("--no-open", action="store_true")
    p.set_defaults(func=cmd_ui)

    sub.add_parser("projects", help="List known projects").set_defaults(func=lambda a: cmd_projects())
    sub.add_parser("migrate",  help="Migrate old in-repo .claude/ setup to ckpt").set_defaults(func=lambda a: cmd_migrate())

    args = parser.parse_args()

    if args.hook == "save-prompt":
        hook_save_prompt(); return
    if args.hook == "checkpoint":
        hook_checkpoint(); return

    if not args.cmd:
        parser.print_help()
        return
    args.func(args)


if __name__ == "__main__":
    main()
