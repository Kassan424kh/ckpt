def die(msg, code=1):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(code)


def _resolve_ref(root, arg):
    """Like the bash CLI: latest/last/-1, -N, full timestamp, partial, or full ref."""
    if not arg:
        return ""
    if arg in ("latest", "last", "-1"):
        out, _, _ = git("for-each-ref", f"{REF_NS}/", "--sort=-refname", "--format=%(refname)", "--count=1", cwd=root)
        return out.strip()
    if re.match(r"^-\d+$", arg):
        n = int(arg[1:])
        out, _, _ = git("for-each-ref", f"{REF_NS}/", "--sort=-refname", "--format=%(refname)", cwd=root)
        lines = [l for l in out.splitlines() if l.strip()]
        return lines[n - 1] if 1 <= n <= len(lines) else ""
    _, _, code = git("rev-parse", "--verify", arg, cwd=root)
    if code == 0:
        return arg
    candidate = f"{REF_NS}/{arg}"
    _, _, code = git("rev-parse", "--verify", candidate, cwd=root)
    if code == 0:
        return candidate
    out, _, _ = git("for-each-ref", f"{REF_NS}/", "--sort=-refname", "--format=%(refname)", cwd=root)
    for line in out.splitlines():
        if arg in line:
            return line.strip()
    return ""


def _format_msg(subject):
    msg = re.sub(r"^On [^:]+: ", "", subject)
    msg = msg.replace("\t", " ")
    return msg[:57] + "..." if len(msg) > 60 else msg


def cmd_list():
    root = project_root()
    if not is_git_repo(root):
        die("not a git repository")
    rows = list_checkpoints(root)
    if not rows:
        print("(no checkpoints)")
        return
    for r in rows:
        s = r["stats"]
        stats_str = ""
        parts = []
        if s["insertions"]:
            parts.append(f"+{s['insertions']}")
        if s["deletions"]:
            parts.append(f"-{s['deletions']}")
        if s["files"]:
            parts.append(f"{s['files']}f")
        if parts:
            stats_str = "  " + " ".join(parts)
        print(f"{r['when']:<16}  {_format_msg(r['message']):<55}  {r['id']}{stats_str}")


def cmd_show(args):
    root = project_root()
    ref = _resolve_ref(root, args.ref)
    if not ref:
        die(f"checkpoint not found: {args.ref}")
    out, _, _ = git("diff", f"{ref}^", ref, cwd=root)
    sys.stdout.write(out)


def cmd_latest():
    root = project_root()
    out, _, _ = git("for-each-ref", f"{REF_NS}/", "--sort=-refname", "--format=%(refname)", "--count=1", cwd=root)
    ref = out.strip()
    if not ref:
        print("(no checkpoints)")
        return
    cid = ref.rsplit("/", 1)[-1]
    out, _, _ = git("for-each-ref", ref, "--format=%(authordate:relative)\t%(contents:subject)", cwd=root)
    when, _, subject = out.strip().partition("\t")
    print(f"{when:<16}  {_format_msg(subject):<55}  {cid}")
    print()
    out, _, _ = git("diff", "--stat", f"{ref}^", ref, cwd=root)
    sys.stdout.write(out)


