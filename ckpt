#!/usr/bin/env python3
"""
ckpt — per-turn git-ref checkpoints for Claude Code, multi-project.

Modes:
    ckpt --hook save-prompt        UserPromptSubmit hook
    ckpt --hook checkpoint         Stop hook
    ckpt ui                        Launch web UI
    ckpt list                      List current project's checkpoints
    ckpt show <ref>                Diff of a checkpoint
    ckpt restore [<ref> [path]]    Interactive picker, or full / single-file restore
    ckpt undo                      Roll back the last restore
    ckpt delete <ref>              Delete one checkpoint
    ckpt latest                    Info about the newest checkpoint
    ckpt prune <n>                 Keep only the most recent N
    ckpt clean                     Delete all checkpoints
    ckpt projects                  List known projects
    ckpt migrate                   Migrate an old in-repo .claude/ install to this one
    ckpt --help

Storage:
    Per-project:
        <project>/.claude/checkpoints.db        prompts + checkpoint metadata
        <project>/.git/refs/claude-checkpoints  snapshot refs (immutable commits)
    Per-machine:
        ~/.local/share/ckpt/projects.db         index of known projects
        ~/.local/share/ckpt/web/                web UI assets (installed by install.sh)
"""

