def cmd_migrate():
    """Move a project from the old in-repo .claude/ setup to the system-wide ckpt."""
    root = project_root()
    if not is_git_repo(root):
        die("not a git repository")

    print(f"migrating {root}")
    pid = register_project(root)
    print(f"  registered as project {pid}")

    legacy = [
        ".claude/hooks/save-prompt.sh",
        ".claude/hooks/checkpoint.sh",
        ".claude/checkpoint.sh",
        ".claude/checkpoint-ui.py",
        ".claude/CHECKPOINTS.md",
    ]
    removed = 0
    for rel in legacy:
        p = Path(root) / rel
        if p.exists():
            p.unlink()
            removed += 1
            print(f"  removed: {rel}")

    hooks_dir = Path(root) / ".claude/hooks"
    if hooks_dir.exists() and not any(hooks_dir.iterdir()):
        hooks_dir.rmdir()
        print("  removed: .claude/hooks/")

    settings_path = Path(root) / ".claude/settings.json"
    if settings_path.exists():
        try:
            data = json.loads(settings_path.read_text())
        except Exception:
            data = {}
        if "hooks" in data:
            for event in ("UserPromptSubmit", "Stop"):
                if event in data["hooks"]:
                    kept = []
                    for entry in data["hooks"][event]:
                        new_hooks = [h for h in entry.get("hooks", [])
                                     if "checkpoint.sh" not in h.get("command", "")
                                     and "save-prompt.sh" not in h.get("command", "")]
                        if new_hooks:
                            entry["hooks"] = new_hooks
                            kept.append(entry)
                    if kept:
                        data["hooks"][event] = kept
                    else:
                        del data["hooks"][event]
            if not data["hooks"]:
                del data["hooks"]
            settings_path.write_text(json.dumps(data, indent=2) + "\n")
            print("  cleaned: .claude/settings.json (hooks block)")

    new_db = project_db_path(Path(root))
    if new_db.exists():
        print(f"  moved:   .claude/checkpoints.db → {new_db}")
    print("  kept:    refs/claude-checkpoints/* (your snapshots)")
    print()
    print("Migration done. The global hook in ~/.claude/settings.json now handles this project.")


# ---------------- update check / self-update ----------------

_update_cache = {}  # { 'data': {...}, 'ts': epoch }
_running_server  = None   # set by cmd_ui; consulted by _do_restart
_running_ui_port = None   # set by cmd_ui


def installed_version():
    try:
        return VERSION_FILE.read_text().strip() or None
    except Exception:
        return None


def _gh_get_json(url, timeout=10):
    import urllib.request
    req = urllib.request.Request(url, headers={"User-Agent": "ckpt-update-check"})
    with urllib.request.urlopen(req, timeout=timeout) as r:
        return json.loads(r.read().decode())


def check_for_updates():
    """Return {ok, current, latest, behind, commits[], error?}. Cached 5 min."""
    now = time.time()
    cached = _update_cache.get("data")
    if cached and (now - _update_cache.get("ts", 0)) < UPDATE_CACHE_TTL:
        return cached

    current = installed_version()
    result = {"ok": True, "current": current, "latest": None, "behind": 0, "commits": []}
    try:
        if current:
            cmp_url = f"https://api.github.com/repos/{GITHUB_REPO}/compare/{current}...main"
            data = _gh_get_json(cmp_url)
            result["latest"]  = data.get("head", {}).get("sha")
            result["behind"]  = int(data.get("ahead_by") or 0)
            result["commits"] = [{
                "sha":     c.get("sha", "")[:8],
                "subject": (c.get("commit", {}).get("message") or "").split("\n", 1)[0],
                "date":    c.get("commit", {}).get("author", {}).get("date") or "",
                "author":  c.get("commit", {}).get("author", {}).get("name") or "",
            } for c in (data.get("commits") or [])][::-1]  # newest first
        else:
            data = _gh_get_json(f"https://api.github.com/repos/{GITHUB_REPO}/commits/main")
            result["latest"] = data.get("sha")
            result["behind"] = 1
            result["commits"] = [{
                "sha":     (data.get("sha") or "")[:8],
                "subject": (data.get("commit", {}).get("message") or "").split("\n", 1)[0],
                "date":    data.get("commit", {}).get("author", {}).get("date") or "",
                "author":  data.get("commit", {}).get("author", {}).get("name") or "",
            }]
    except Exception as e:
        result = {"ok": False, "current": current, "error": str(e),
                  "latest": None, "behind": 0, "commits": []}

    _update_cache["data"] = result
    _update_cache["ts"]   = now
    return result


def op_self_update():
    """Download the main tarball from GitHub, extract, and replace only the
    specific files we ship (ckpt + web/*). No shell scripts are executed; no
    user config is touched (~/.claude/settings.json is left as-is since hooks
    are already registered from the initial install). Updates VERSION on success."""
    import urllib.request
    import tarfile
    import tempfile

    tar_url = f"https://github.com/{GITHUB_REPO}/archive/refs/heads/main.tar.gz"
    bin_path = Path.home() / ".local" / "bin" / "ckpt"

    try:
        with tempfile.TemporaryDirectory() as tmp:
            tmp = Path(tmp)
            tar_path = tmp / "src.tar.gz"
            req = urllib.request.Request(tar_url, headers={"User-Agent": "ckpt-update"})
            with urllib.request.urlopen(req, timeout=60) as r, open(tar_path, "wb") as f:
                shutil.copyfileobj(r, f)

            with tarfile.open(tar_path, "r:gz") as t:
                # Defensive extract: only paths we expect, no traversal.
                members = []
                for m in t.getmembers():
                    if ".." in m.name.split("/"):
                        continue
                    if not (m.name.endswith("/ckpt") or "/web/" in m.name):
                        continue
                    members.append(m)
                t.extractall(tmp, members=members)

            roots = [p for p in tmp.glob("ckpt-*") if p.is_dir()]
            if not roots:
                return {"ok": False, "error": "couldn't locate extracted source root"}
            src = roots[0]

            new_ckpt = src / "ckpt"
            if not new_ckpt.exists():
                return {"ok": False, "error": "tarball missing ckpt binary"}

            # Replace binary + web assets.
            bin_path.parent.mkdir(parents=True, exist_ok=True)
            WEB_DIR.mkdir(parents=True, exist_ok=True)
            shutil.copyfile(str(new_ckpt), str(bin_path))
            bin_path.chmod(0o755)
            for name in ("index.html", "app.js", "styles.css"):
                sp = src / "web" / name
                if sp.exists():
                    shutil.copyfile(str(sp), str(WEB_DIR / name))

        # Record the new HEAD SHA. Use git ls-remote — read-only, no shell exec.
        sha = None
        try:
            r = subprocess.run(
                ["git", "ls-remote", f"https://github.com/{GITHUB_REPO}.git", "refs/heads/main"],
                capture_output=True, text=True, timeout=15,
            )
            if r.returncode == 0 and r.stdout.strip():
                sha = r.stdout.split()[0]
        except Exception:
            pass
        if sha:
            VERSION_FILE.write_text(sha + "\n")

        _update_cache.clear()
        # User-authorized: after a successful file replacement, restart the
        # running ckpt ui server so the new Python takes effect for the next
        # request. The HTTP response below flushes first; the restart thread
        # waits a moment then execs a fresh process on the same port.
        _schedule_restart()
        return {"ok": True, "version": sha, "restarting": _running_server is not None}
    except Exception as e:
        return {"ok": False, "error": str(e)}


def _schedule_restart():
    """Kick off a restart in a background thread, after the current HTTP
    response has been sent. No-op outside an active `ckpt ui` server."""
    if _running_server is None:
        return
    threading.Thread(target=_do_restart, daemon=True).start()


def _do_restart():
    # Give the current handler thread time to finish writing its response.
    time.sleep(0.5)
    try:
        if _running_server is not None:
            _running_server.shutdown()
            _running_server.server_close()
    except Exception:
        pass
    time.sleep(0.15)  # let the OS release the listening socket
    script = os.path.abspath(sys.argv[0])
    argv = [sys.executable, script, "ui", "--no-open"]
    if _running_ui_port:
        argv.extend(["--port", str(_running_ui_port)])
    try:
        os.execv(sys.executable, argv)
    except Exception:
        os._exit(1)


